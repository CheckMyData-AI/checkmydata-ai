DEBUG=true
DATABASE_URL=sqlite+aiosqlite:///./data/agent.db

# Required. Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
MASTER_ENCRYPTION_KEY=

# JWT auth. Change in production!
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=change-me-in-production
JWT_EXPIRE_MINUTES=1440

# Google OAuth (Sign In with Google / GIS).
# Get the Web-application Client ID from https://console.cloud.google.com/apis/credentials
# GOOGLE_CLIENT_SECRET is NOT required — GIS uses ID-token verification
# which only needs the Client ID. A secret would only be needed for the
# server-side Authorization Code flow (accessing Google APIs on behalf of users).
GOOGLE_CLIENT_ID=

# Resend transactional email (team invites, welcome emails).
# Get an API key at https://resend.com/api-keys
# You must also verify your sending domain at https://resend.com/domains
RESEND_API_KEY=
RESEND_FROM_EMAIL=CheckMyData <noreply@checkmydata.ai>
APP_URL=http://localhost:3000

DEFAULT_LLM_PROVIDER=openai
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=
CUSTOM_RULES_DIR=./rules
REPO_CLONE_BASE_DIR=./data/repos
# Query validation loop
QUERY_MAX_RETRIES=3
QUERY_ENABLE_EXPLAIN=true
QUERY_ENABLE_SCHEMA_VALIDATION=true
QUERY_EMPTY_RESULT_RETRY=false
QUERY_EXPLAIN_ROW_WARNING_THRESHOLD=100000
QUERY_TIMEOUT_SECONDS=30

CORS_ORIGINS=["http://localhost:3000","http://localhost:3100","https://checkmydata.ai"]

# Admin emails (comma-separated) seeded with can_create_projects=true
# Only needed for the hosted version with project creation gating
# ADMIN_EMAILS=admin@example.com,admin2@example.com

# --- Optional / Advanced settings below ---
# Uncomment and adjust as needed. Defaults are shown.

# ChromaDB vector store
# CHROMA_PERSIST_DIR=./data/chroma
# CHROMA_SERVER_URL=              # Use remote ChromaDB server instead of local
# CHROMA_EMBEDDING_MODEL=         # Custom embedding model name

# Chat history & context
# MAX_HISTORY_TOKENS=4000
# HISTORY_SUMMARY_MODEL=          # Cheaper model for history summarization
# MAX_CONTEXT_TOKENS=16000

# Session rotation (auto-summarize near context limit)
# SESSION_ROTATION_ENABLED=true
# SESSION_ROTATION_THRESHOLD_PCT=95
# SESSION_ROTATION_SUMMARY_MAX_TOKENS=500

# Orchestrator / agent limits
# MAX_ORCHESTRATOR_ITERATIONS=25
# ORCHESTRATOR_WRAP_UP_STEPS=3
# AGENT_WALL_CLOCK_TIMEOUT_SECONDS=90
# MAX_PARALLEL_TOOL_CALLS=2
# MAX_SUB_AGENT_RETRIES=2
# MAX_SQL_ITERATIONS=3
# MAX_MCP_ITERATIONS=5
# MAX_KNOWLEDGE_ITERATIONS=2
# MAX_INVESTIGATION_ITERATIONS=12

# Database index settings
# DB_INDEX_TTL_HOURS=24
# DB_INDEX_BATCH_SIZE=5
# AUTO_INDEX_DB_ON_TEST=false

# Pipeline settings
# PIPELINE_RUN_TTL_DAYS=7
# MAX_STAGE_RETRIES=2

# Streaming
# STREAM_TIMEOUT_SECONDS=120
# STREAM_SAFETY_MARGIN_SECONDS=90

# Backup (automated daily)
# BACKUP_ENABLED=true
# BACKUP_HOUR=0
# BACKUP_RETENTION_DAYS=7
# BACKUP_DIR=./data/backups

# Token budget limits (0 = unlimited)
# DAILY_TOKEN_LIMIT=0
# MONTHLY_TOKEN_LIMIT=0

# Request limits
# MAX_CONCURRENT_AGENT_CALLS=3
# MAX_AGENT_CALLS_PER_HOUR=100

# Query cache persistence (empty = in-memory only)
# QUERY_CACHE_PERSIST_DIR=

# Redis (enables shared cache + ARQ task queue; empty = in-process fallback)
# REDIS_URL=

# GeoIP cache
# GEOIP_CACHE_ENABLED=true
# GEOIP_CACHE_DIR=./data
# GEOIP_MEMORY_CACHE_SIZE=100000

# External service timeouts
# MODEL_CACHE_TTL_SECONDS=3600
# HEALTH_DEGRADED_LATENCY_MS=3000
# SSH_CONNECT_TIMEOUT=30
# SSH_COMMAND_TIMEOUT=60

# Connection pool
# DB_POOL_SIZE=5
# DB_POOL_OVERFLOW=10
# DB_POOL_RECYCLE=3600
# DB_POOL_TIMEOUT=30
