# =============================================================================
# CheckMyData.ai backend configuration (.env.example)
# Synced with app/config.py — keys here mirror Settings field names.
# Required keys are at the top; everything below is optional with shown defaults.
# =============================================================================

# ----- Core --------------------------------------------------------------------
# APP_NAME=CheckMyData.ai
ENVIRONMENT=development          # "development" | "staging" | "production"
DEBUG=true
SQL_ECHO=false
DATABASE_URL=sqlite+aiosqlite:///./data/agent.db

# Required. Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
MASTER_ENCRYPTION_KEY=

# JWT auth. Change in production!
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440           # 24 hours

# Browser session cookies (T-SEC-3). The JWT is sent to browsers as an
# httpOnly/Secure/SameSite cookie (never localStorage), with a non-httpOnly
# CSRF cookie for the double-submit check. Bearer tokens still work for API
# clients. Set AUTH_COOKIE_SECURE=false only for local http development.
# AUTH_COOKIE_ENABLED=true
# AUTH_COOKIE_SECURE=true
# AUTH_COOKIE_SAMESITE=lax          # lax | strict | none
# AUTH_COOKIE_DOMAIN=               # empty = host-only cookie

# Google OAuth (Sign In with Google / GIS).
GOOGLE_CLIENT_ID=

# Resend transactional email (team invites, welcome emails).
# Verify your sending domain at https://resend.com/domains
RESEND_API_KEY=
RESEND_FROM_EMAIL=CheckMyData <noreply@checkmydata.ai>
APP_URL=http://localhost:3000

# ----- LLM providers -----------------------------------------------------------
DEFAULT_LLM_PROVIDER=openai
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=

# ----- Filesystem --------------------------------------------------------------
CUSTOM_RULES_DIR=./rules
REPO_CLONE_BASE_DIR=./data/repos
INCLUDE_SAMPLE_DATA=false

# ----- Live Git access (GitInspector / GitAgent, read-only) --------------------
# Refresh the local clone before answering when it has fallen behind the indexed
# HEAD. Off by default (a pull costs network IO and can block on auth).
GIT_AGENT_AUTO_PULL=false
GIT_CLONE_PULL_TIMEOUT_S=60
# Bounded iterations for the GitAgent tool-calling loop.
MAX_GIT_ITERATIONS=6
# Output guards so a single huge file/diff cannot blow up memory or LLM context.
GIT_MAX_OUTPUT_BYTES=100000
GIT_MAX_LOG_COUNT=200
# Warn the agent when the local clone is this many commits behind the indexed HEAD.
GIT_STALENESS_WARN_COMMITS=5

# ----- CORS --------------------------------------------------------------------
CORS_ORIGINS=["http://localhost:3000","http://localhost:3100","https://checkmydata.ai"]

# ----- Security headers (T-SEC-6) ---------------------------------------------
# Content-Security-Policy + HSTS are emitted by SecurityHeadersMiddleware.
# CSP is enforced by default; flip to report-only to observe violations first.
# SECURITY_CSP_ENABLED=true
# SECURITY_CSP_REPORT_ONLY=false
# SECURITY_CSP="default-src 'self'; ..."   # override the built-in policy
# HSTS is only emitted over HTTPS (honors X-Forwarded-Proto behind a proxy).
# SECURITY_HSTS_ENABLED=true
# SECURITY_HSTS_MAX_AGE=31536000
# SECURITY_HSTS_INCLUDE_SUBDOMAINS=true
# SECURITY_HSTS_PRELOAD=false

# ----- Admin gating ------------------------------------------------------------
# Users matching ADMIN_EMAILS get access to admin-only endpoints (manual backup
# trigger, cluster metrics, etc.). JSON list:
# ADMIN_EMAILS=["admin@example.com"]

# =============================================================================
# Optional knobs — all have sensible defaults. Uncomment to override.
# =============================================================================

# ----- Query validation loop ---------------------------------------------------
# QUERY_MAX_RETRIES=3
# QUERY_ENABLE_EXPLAIN=true
# QUERY_ENABLE_SCHEMA_VALIDATION=true
# QUERY_EMPTY_RESULT_RETRY=true   # treat 0-row results as a retry signal (R5-2)
# QUERY_EXPLAIN_ROW_WARNING_THRESHOLD=100000
# QUERY_TIMEOUT_SECONDS=30
# ORCHESTRATOR_RESULT_GATE_ENABLED=true     # unified-path result-quality gate (R5-3)
# ORCHESTRATOR_MAX_RESULT_CORRECTIONS=2     # bound on re-query nudges per workflow
# ORCHESTRATOR_AUTO_INVESTIGATE_ENABLED=false  # auto-route suspicious results to the investigation agent (R5-7)

# ----- ChromaDB vector store ---------------------------------------------------
# CHROMA_PERSIST_DIR=./data/chroma
# CHROMA_SERVER_URL=
# CHROMA_EMBEDDING_MODEL=

# ----- Chat history & context --------------------------------------------------
# MAX_HISTORY_TOKENS=2500
# HISTORY_SUMMARY_MODEL=
# MAX_CONTEXT_TOKENS=32000
# HISTORY_TAIL_MESSAGES=4
# HISTORY_DB_LOAD_LIMIT=20

# ----- Session rotation --------------------------------------------------------
# SESSION_ROTATION_ENABLED=true
# SESSION_ROTATION_THRESHOLD_PCT=95
# SESSION_ROTATION_SUMMARY_MAX_TOKENS=500

# ----- Orchestrator / agent limits --------------------------------------------
# MAX_ORCHESTRATOR_ITERATIONS=100
# ORCHESTRATOR_FINAL_SYNTHESIS=true
# AGENT_WALL_CLOCK_TIMEOUT_SECONDS=180
# MAX_PARALLEL_TOOL_CALLS=2
# MAX_SUB_AGENT_RETRIES=2
# MAX_SQL_ITERATIONS=10
# MAX_MCP_ITERATIONS=5
# MAX_KNOWLEDGE_ITERATIONS=2
# MAX_INVESTIGATION_ITERATIONS=12
# AGENT_EMERGENCY_SYNTHESIS_PCT=0.90
# ROUTER_MODEL=
# RAG_RELEVANCE_THRESHOLD=0.8
# SCHEMA_CACHE_TTL_SECONDS=300
# MAX_PIE_CATEGORIES=20
# VIZ_TIMEOUT_SECONDS=15
# SYNTHESIS_DATA_TOKEN_BUDGET_PCT=0.4
# MIN_SYNTHESIS_LENGTH=0
# SLOW_QUERY_WARNING_MS=30000

# ----- Answer validator (T12) -------------------------------------------------
# ANSWER_VALIDATOR_ENABLED=true
# ANSWER_VALIDATOR_MIN_CHARS=80
# ANSWER_VALIDATOR_FAIL_CLOSED=true         # post-timeout validator errors mark the answer unverified (R5-6)
# ORCHESTRATOR_PIPELINE_TABLE_THRESHOLD=3
# LLM_RESULT_PREVIEW_ROWS=50

# ----- Tool-call dedup (T13) --------------------------------------------------
# TOOL_DEDUP_SEMANTIC_THRESHOLD=0.85
# TOOL_DEDUP_WORD_OVERLAP_THRESHOLD=0.8
# TOOL_DEDUP_EMBEDDING_MODEL=

# ----- DataGate thresholds (T07) ----------------------------------------------
# DATA_GATE_MAX_SAMPLE=200
# DATA_GATE_HIGH_NULL_RATIO=0.5
# DATA_GATE_HIGH_DUPLICATE_RATIO=0.9
# DATA_GATE_VALUE_RANGE_SAMPLE=50
# DATA_GATE_PERCENT_MIN=-1.0
# DATA_GATE_PERCENT_MAX=200.0
# DATA_GATE_YEAR_MIN=1900
# DATA_GATE_YEAR_MAX=2100
# DATA_GATE_CARTESIAN_MULTIPLIER=100
# DATA_GATE_LLM_SEMANTICS=false
# DATA_GATE_COMMON_LIMITS=[100,500,1000,5000,10000,50000]

# ----- Database index settings -------------------------------------------------
# DB_INDEX_TTL_HOURS=24
# DB_INDEX_BATCH_SIZE=5
# AUTO_INDEX_DB_ON_TEST=false
# DB_INDEX_INCREMENTAL_ENABLED=true   # diff-only schema reindex on refresh (R2-3)

# ----- Knowledge lifecycle maintenance ----------------------------------------
# How often (hours) the background loop runs learning/session-note confidence
# decay and insight TTL/decay. Independent of backups so decay always runs.
# MAINTENANCE_INTERVAL_HOURS=24

# ----- Pipeline settings -------------------------------------------------------
# PIPELINE_RUN_TTL_DAYS=7
# MAX_STAGE_RETRIES=2
# MAX_PIPELINE_REPLANS=2
# PIPELINE_MAX_PARALLEL_STAGES=3

# ----- Streaming ---------------------------------------------------------------
# STREAM_TIMEOUT_SECONDS=360
# STREAM_SAFETY_MARGIN_SECONDS=120

# ----- Backup (automated daily) -----------------------------------------------
# BACKUP_ENABLED=true
# BACKUP_HOUR=0
# BACKUP_RETENTION_DAYS=7
# BACKUP_DIR=./data/backups

# ----- Request limits ----------------------------------------------------------
# MAX_REQUEST_BODY_BYTES=10485760
# MAX_CONCURRENT_AGENT_CALLS=3
# MAX_AGENT_CALLS_PER_HOUR=100

# ----- Batch query execution (T19) --------------------------------------------
# BATCH_MAX_CONCURRENCY=4
# BATCH_RESULT_ROW_CAP=500

# ----- Chat router knobs (T25) -------------------------------------------------
# CHAT_RAW_RESULT_ROW_CAP=500
# CHAT_SQL_EXPLAIN_CACHE_MAX=100
# TOOL_PREVIEW_MAX_CHARS=500
# TOOL_RESULT_MAX_CHARS=500
# MAX_LESSON_LENGTH=500
# HEALTH_CHECK_INTERVAL_SECONDS=300

# ----- Redis / task queue ------------------------------------------------------
# REDIS_URL=

# ----- MCP server (T-SEC-1) ----------------------------------------------------
# The MCP tool surface is OFF by default. To run `python -m app.mcp_server` you
# must enable it AND bind its API key to a real platform user so every tool call
# is scoped/authorized exactly like that user's HTTP requests. Without the
# binding the server refuses to start and the API key is rejected.
# MCP_ENABLED=false
# MCP_API_KEY_USER_ID=                 # platform user id the API key acts as
# CHECKMYDATA_API_KEY=                 # server-level MCP API key (or MCP_API_KEY)

# ----- GeoIP cache -------------------------------------------------------------
# GEOIP_CACHE_ENABLED=true
# GEOIP_CACHE_DIR=./data
# GEOIP_MEMORY_CACHE_SIZE=100000

# ----- External service timeouts ----------------------------------------------
# MODEL_CACHE_TTL_SECONDS=3600
# HEALTH_DEGRADED_LATENCY_MS=3000
# SSH_CONNECT_TIMEOUT=30
# SSH_COMMAND_TIMEOUT=60
# SSH_HOST_KEY_POLICY=disabled        # disabled | tofu | strict (R1-2)
#   disabled — no host-key verification (legacy default, MITM-exposed)
#   tofu     — trust-on-first-use: pin the key on first connect, verify after
#   strict   — verify against SSH_KNOWN_HOSTS_PATH only; reject unknown hosts
# SSH_KNOWN_HOSTS_PATH=/tmp/checkmydata_known_hosts  # writable store for tofu/strict keys (R1-2)

# ----- Connection pool ---------------------------------------------------------
# DB_POOL_SIZE=5
# DB_POOL_OVERFLOW=10
# DB_POOL_RECYCLE=3600
# DB_POOL_TIMEOUT=30

# ----- Knowledge / learnings (T06) --------------------------------------------
# LEARNING_WEIGHT_CONFIDENCE=0.4
# LEARNING_WEIGHT_CONFIRMED=0.4
# LEARNING_WEIGHT_APPLIED=0.2
# LEARNING_ANALYZER_MODE=llm_first   # heuristic | hybrid | llm_first
# LEARNING_SUBJECT_BLOCKLIST_EXTRA=[]
# LEARNING_APPLY_ON_VALIDATION_ENABLED=true   # apply learnings when a result validates (R4-2)
# INSIGHT_TTL_DAYS_LOW=7
# INSIGHT_TTL_DAYS_WARNING=30
# INSIGHT_TTL_DAYS_CRITICAL=0
# Cross-connection learning injection (V1, vision §7 #4). Default: disabled
# so every connection's prompt contains only its own learnings. Opt-in to
# `true` only if you explicitly want sibling-connection promotion.
# CROSS_CONNECTION_LEARNINGS_ENABLED=false
# Tolerated failure ratio for generate_docs (C2, v1.13.0). Single transient
# LLM errors should not abort an entire indexing run; above this ratio the
# step fails so an operator sees the problem before silent KB drift.
# GENERATE_DOCS_MAX_FAILURE_RATIO=0.3
# DataGate hard checks (C4, v1.13.0). When true (default), out-of-range
# percent/date values fail the gate (triggering a stage retry) instead of
# emitting a warning. Set to false to revert to v1.12.x warn-only behavior.
# DATA_GATE_HARD_CHECKS_ENABLED=true

# ----- Code intelligence pipeline (M1-M6) -------------------------------------
# Master flag: enables tree-sitter AST parsing + code knowledge graph.
# When false, the legacy regex-based entity_extractor path runs.
# CODE_GRAPH_ENABLED=false
# AST_PARSE_CONCURRENCY=4
# AST_MAX_FILE_BYTES=2097152
# AST_PARSE_ERROR_RATIO=0.3
# CODE_GRAPH_MAX_SYMBOLS=50000
# CODE_GRAPH_CALL_CONFIDENCE_THRESHOLD=0.3

# M3: hybrid retrieval (BM25 + Chroma fused via RRF).
# HYBRID_RETRIEVAL_ENABLED=false
# BM25_DATA_DIR=./data/bm25
# HYBRID_RRF_K=60
# HYBRID_MIN_SCORE=0.01
# HYBRID_K=20

# M4: question-aware schema retrieval (BM25 + embeddings over DbIndex).
# SCHEMA_RETRIEVAL_ENABLED=false
# SQL_AGENT_MAX_CONTEXT_TABLES=15

# M5: graph-driven code-to-DB lineage.
# LINEAGE_ENABLED=false
# LINEAGE_MAX_DEPTH=5

# M6: functional clustering (Louvain) + LLM-labeled cluster names.
# CLUSTERING_ENABLED=false
# CLUSTER_LLM_LABEL_ENABLED=true
