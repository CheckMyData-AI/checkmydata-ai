DEBUG=true
DATABASE_URL=sqlite+aiosqlite:///./data/agent.db

# Required. Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
MASTER_ENCRYPTION_KEY=

# JWT auth. Change in production!
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=change-me-in-production
JWT_EXPIRE_MINUTES=1440

# Google OAuth. Get from https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=

DEFAULT_LLM_PROVIDER=openai
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=
CUSTOM_RULES_DIR=./rules
REPO_CLONE_BASE_DIR=./data/repos
# Query validation loop
QUERY_MAX_RETRIES=3
QUERY_ENABLE_EXPLAIN=true
QUERY_ENABLE_SCHEMA_VALIDATION=true
QUERY_EMPTY_RESULT_RETRY=false
QUERY_EXPLAIN_ROW_WARNING_THRESHOLD=100000
QUERY_TIMEOUT_SECONDS=30

CORS_ORIGINS=["http://localhost:3000"]
