NEXT_PUBLIC_API_URL=http://localhost:8000/api

# Google OAuth. Get from https://console.cloud.google.com/apis/credentials
# Must match the GOOGLE_CLIENT_ID set in backend/.env
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Sentry error tracking (optional). Off unless the DSN is set.
# PII is scrubbed client- and server-side before send.
# NEXT_PUBLIC_SENTRY_DSN=
# NEXT_PUBLIC_SENTRY_ENVIRONMENT=
# NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0
# Source-map upload at build time (CI only):
# SENTRY_ORG=
# SENTRY_PROJECT=
# SENTRY_AUTH_TOKEN=
